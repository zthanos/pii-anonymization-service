# ============================================================================
# PII Anonymization Service - Environment Configuration
# ============================================================================
# This file contains all environment variables needed to run the service.
# Copy this file to .env and fill in your actual values.
# ============================================================================

# ----------------------------------------------------------------------------
# Redis Configuration
# ----------------------------------------------------------------------------
# Redis connection URL (format: redis://[password@]host:port/db)
REDIS_URL=redis://localhost:6379/0

# Redis connection pool size (default: 50)
REDIS_POOL_SIZE=50

# ----------------------------------------------------------------------------
# Policy Configuration
# ----------------------------------------------------------------------------
# Path to YAML policy file defining PII fields and tokenization rules
POLICY_PATH=policies/example_policy.yaml

# ----------------------------------------------------------------------------
# Encryption Keys
# ----------------------------------------------------------------------------
# 32-byte base64-encoded encryption keys for each system
# Generate with: uv run python scripts/generate_key.py
#
# IMPORTANT: Keep these keys secure! Store in secrets manager in production.
# Each system_id in your policy file needs a corresponding key here.

CUSTOMER_DB_KEY=your-32-byte-base64-encoded-key-here
ANALYTICS_DB_KEY=your-32-byte-base64-encoded-key-here

# ----------------------------------------------------------------------------
# LLM API Configuration
# ----------------------------------------------------------------------------
# Anthropic API key for Claude LLM (required for unstructured tokenization)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ----------------------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------------------
# HTTP REST API port
HTTP_PORT=8000

# gRPC streaming API port
GRPC_PORT=50051

# Maximum number of gRPC worker threads
GRPC_MAX_WORKERS=10

# Server host (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
HOST=0.0.0.0

# ----------------------------------------------------------------------------
# Logging Configuration
# ----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# TLS/SSL Configuration (Optional)
# ----------------------------------------------------------------------------
# Enable TLS for secure communications
# Leave empty to run without TLS (not recommended for production)

# Path to SSL private key file
SSL_KEYFILE=

# Path to SSL certificate file
SSL_CERTFILE=

# Path to SSL CA certificates file (for client authentication)
SSL_CA_CERTS=

# ----------------------------------------------------------------------------
# API Authentication
# ----------------------------------------------------------------------------
# API key for authenticating requests
# In production, use a secrets manager and rotate keys regularly
# Format: Bearer token in Authorization header

API_KEY=your-secure-api-key-here

# ----------------------------------------------------------------------------
# Docker Compose Specific (for local development)
# ----------------------------------------------------------------------------
# Redis password for docker-compose setup
REDIS_PASSWORD=redis_dev_password
